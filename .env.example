# CreatorHQ — environment template
# Copy to .env (gitignored) and fill in values.

# --- App ---
PORT=3001
NODE_ENV=development

# --- Storage mode ---
# Set this to true to skip Supabase entirely and use the filesystem-only path.
# Recommended for the pilot deploy until Supabase is re-confirmed reachable + populated.
# CREATORHQ_DISABLE_SUPABASE=true

# Per-call timeout (ms) before falling back from Supabase to filesystem.
# Default 2000. Lower if you want faster fallback when offline; higher on flaky links.
# CREATORHQ_SUPABASE_TIMEOUT_MS=2000

# --- Supabase (only required when CREATORHQ_DISABLE_SUPABASE is not true) ---
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# SUPABASE_SECRET_KEY=eyJ...     # SERVER ONLY. Never commit. Rotate if leaked.

# --- Auth ---
# Auth routes (/auth/callback, /api/auth/login, /api/auth/verify) are gated.
# Pilot deploy: leave unset or false. They return 503.
# Production: set true ONLY after the WhatsApp OTP storage path is wired (P0 from QA 2026-05-01).
# CREATORHQ_AUTH_ENABLED=false

# Express session signing (cookie-based auth). REQUIRED in production.
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-32-bytes-of-hex

# --- Public-facing site URL ---
# Used in auth redirect URIs. On Railway this is set to the production domain.
SITE_URL=http://localhost:3001
